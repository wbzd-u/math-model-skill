{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Implementation Provenance",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contract_id", "mode", "status", "distribution_context", "sources", "reuse_records", "custom_components"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "contract_id": {"type": "string", "minLength": 1},
    "mode": {"enum": ["probe", "solve"]},
    "status": {"enum": ["DRAFT", "READY", "BLOCKED"]},
    "distribution_context": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "title", "canonical_url", "official_docs_url", "version_or_identifier", "repository_commit", "accessed_at", "verification_status", "license", "decision"],
        "properties": {
          "id": {"type": "string", "pattern": "^ext-[0-9]{3}$"},
          "kind": {"enum": ["library", "source-code", "paper", "official-document", "dataset", "commercial-software", "standard"]},
          "title": {"type": "string", "minLength": 1},
          "canonical_url": {"type": ["string", "null"]},
          "official_docs_url": {"type": ["string", "null"]},
          "version_or_identifier": {"type": ["string", "null"]},
          "repository_commit": {"type": ["string", "null"]},
          "accessed_at": {"type": ["string", "null"]},
          "verification_status": {"enum": ["verified-primary", "verified-secondary", "provisional", "unverified"]},
          "license": {
            "type": "object",
            "additionalProperties": false,
            "required": ["spdx_id", "status", "evidence_ref", "compatibility", "obligations"],
            "properties": {
              "spdx_id": {"type": ["string", "null"]},
              "status": {"enum": ["verified", "unknown", "not-applicable"]},
              "evidence_ref": {"type": ["string", "null"]},
              "compatibility": {"enum": ["compatible", "incompatible", "unassessed", "not-applicable"]},
              "obligations": {"type": "array", "items": {"type": "string"}}
            }
          },
          "decision": {"enum": ["selected", "rejected", "blocked"]}
        }
      }
    },
    "reuse_records": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "component_ids", "execution_stage_ids", "source_ids", "reuse_kind", "upstream_locators", "local_paths", "purpose", "modifications", "semantic_deviations", "attribution_required", "attribution_locations", "obligations_satisfied", "validation_test_ids"],
        "properties": {
          "id": {"type": "string", "pattern": "^reuse-[0-9]{3}$"},
          "component_ids": {"type": "array", "items": {"type": "string", "pattern": "^cmp-[0-9]{3}$"}, "minItems": 1},
          "execution_stage_ids": {"type": "array", "items": {"type": "string", "pattern": "^run-[0-9]{2}$"}},
          "source_ids": {"type": "array", "items": {"type": "string", "pattern": "^ext-[0-9]{3}$"}, "minItems": 1},
          "reuse_kind": {"enum": ["package-api", "adapted-code", "copied-code", "vendored-code", "independent-paper-implementation", "benchmark", "conceptual-reference"]},
          "upstream_locators": {"type": "array", "items": {"type": "string"}},
          "local_paths": {"type": "array", "items": {"type": "string"}},
          "purpose": {"type": "string", "minLength": 1},
          "modifications": {"type": "array", "items": {"type": "string"}},
          "semantic_deviations": {"type": "array", "items": {"type": "string"}},
          "attribution_required": {"type": "boolean"},
          "attribution_locations": {"type": "array", "items": {"type": "string"}},
          "obligations_satisfied": {"type": "boolean"},
          "validation_test_ids": {"type": "array", "items": {"type": "string", "pattern": "^val-[0-9]{3}$"}}
        }
      }
    },
    "custom_components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["component_ids", "reason", "alternatives_considered", "rejection_reasons", "correctness_checks"],
        "properties": {
          "component_ids": {"type": "array", "items": {"type": "string", "pattern": "^cmp-[0-9]{3}$"}, "minItems": 1},
          "reason": {"type": "string", "minLength": 1},
          "alternatives_considered": {"type": "array", "items": {"type": "string"}},
          "rejection_reasons": {"type": "array", "items": {"type": "string"}},
          "correctness_checks": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1}
        }
      }
    }
  }
}
