{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Solver Reproducibility Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "status", "platform", "runtimes", "dependencies", "environment_files", "input_files", "source_files", "config_files", "seeds", "commands", "verified_command_ids", "notes"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "run_id": {"type": "string", "pattern": "^(probe|solve)-[0-9]{3}$"},
    "status": {"enum": ["DRAFT", "COMPLETE", "PARTIAL"]},
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "os_version", "architecture", "hardware", "timezone"],
      "properties": {
        "os": {"type": ["string", "null"]},
        "os_version": {"type": ["string", "null"]},
        "architecture": {"type": ["string", "null"]},
        "hardware": {"type": ["string", "null"]},
        "timezone": {"type": ["string", "null"]}
      }
    },
    "runtimes": {"type": "array", "items": {"type": "object", "required": ["name", "version"], "properties": {"name": {"type": "string"}, "version": {"type": "string"}}}},
    "dependencies": {"type": "array", "items": {"type": "object", "required": ["name", "version", "source_id"], "properties": {"name": {"type": "string"}, "version": {"type": "string"}, "source_id": {"type": ["string", "null"]}}}},
    "environment_files": {"$ref": "#/$defs/hashedFiles"},
    "input_files": {"$ref": "#/$defs/hashedFiles"},
    "source_files": {"$ref": "#/$defs/hashedFiles"},
    "config_files": {"$ref": "#/$defs/hashedFiles"},
    "seeds": {"type": "array", "items": {"type": "integer"}},
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "command", "working_directory", "experiment_ids"],
        "properties": {
          "id": {"type": "string", "pattern": "^cmd-[0-9]{3}$"},
          "command": {"type": "string", "minLength": 1},
          "working_directory": {"type": "string", "minLength": 1},
          "experiment_ids": {"type": "array", "items": {"type": "string", "pattern": "^exp-[0-9]{3}$"}}
        }
      }
    },
    "verified_command_ids": {"type": "array", "items": {"type": "string", "pattern": "^cmd-[0-9]{3}$"}, "uniqueItems": true},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "$defs": {
    "hashedFiles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    }
  }
}
