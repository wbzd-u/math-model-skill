{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Numerical Run Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "run_id", "status", "diagnostic_question", "language", "environment_files", "stages", "simplifications", "numerical_controls", "semantic_deviations"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "mode": {"enum": ["probe", "solve"]},
    "run_id": {"type": "string", "pattern": "^(probe|solve)-[0-9]{3}$"},
    "status": {"enum": ["DRAFT", "READY", "BLOCKED", "FEEDBACK_REQUIRED"]},
    "diagnostic_question": {"type": ["string", "null"]},
    "language": {"type": ["string", "null"]},
    "environment_files": {"type": "array", "items": {"type": "string"}},
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contract_stage_id", "component_ids", "input_bindings", "output_bindings", "source_files", "commands", "invariant_checks", "validation_test_ids", "provenance_record_ids", "status"],
        "properties": {
          "contract_stage_id": {"type": "string", "pattern": "^run-[0-9]{2}$"},
          "component_ids": {"type": "array", "items": {"type": "string", "pattern": "^cmp-[0-9]{3}$"}, "uniqueItems": true},
          "input_bindings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["contract_ref", "binding_kind", "binding_ref", "source_ref", "unit_policy", "status"],
              "properties": {
                "contract_ref": {"type": "string", "minLength": 1},
                "binding_kind": {"enum": ["data", "field", "parameter", "prior-stage", "literal", "generated", "unresolved"]},
                "binding_ref": {"type": ["string", "number", "integer", "boolean", "null"]},
                "source_ref": {"type": ["string", "null"]},
                "unit_policy": {"type": ["string", "null"]},
                "status": {"enum": ["resolved", "partial", "unresolved"]}
              }
            }
          },
          "output_bindings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["contract_ref", "path", "format"],
              "properties": {
                "contract_ref": {"type": "string", "minLength": 1},
                "path": {"type": "string", "minLength": 1},
                "format": {"type": "string", "minLength": 1}
              }
            }
          },
          "source_files": {"type": "array", "items": {"type": "string"}},
          "commands": {"type": "array", "items": {"type": "string"}},
          "invariant_checks": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["statement", "method", "status", "evidence_ref"],
              "properties": {
                "statement": {"type": "string", "minLength": 1},
                "method": {"type": "string", "minLength": 1},
                "status": {"enum": ["PLANNED", "PASSED", "FAILED", "INCONCLUSIVE"]},
                "evidence_ref": {"type": ["string", "null"]}
              }
            }
          },
          "validation_test_ids": {"type": "array", "items": {"type": "string", "pattern": "^val-[0-9]{3}$"}, "uniqueItems": true},
          "provenance_record_ids": {"type": "array", "items": {"type": "string", "pattern": "^reuse-[0-9]{3}$"}, "uniqueItems": true},
          "status": {"enum": ["PLANNED", "READY", "BLOCKED", "COMPLETE"]}
        }
      }
    },
    "simplifications": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "description", "affected_stage_ids", "justification", "unsupported_claims"],
        "properties": {
          "id": {"type": "string", "pattern": "^simp-[0-9]{3}$"},
          "description": {"type": "string", "minLength": 1},
          "affected_stage_ids": {"type": "array", "items": {"type": "string", "pattern": "^run-[0-9]{2}$"}},
          "justification": {"type": "string", "minLength": 1},
          "unsupported_claims": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1}
        }
      }
    },
    "numerical_controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seeds", "tolerances", "stopping_criteria"],
      "properties": {
        "seeds": {"type": "array", "items": {"type": "integer"}, "uniqueItems": true},
        "tolerances": {"type": "array", "items": {"type": "object", "required": ["name", "value", "basis"], "properties": {"name": {"type": "string"}, "value": {"type": ["number", "string"]}, "basis": {"type": "string"}}}},
        "stopping_criteria": {"type": "array", "items": {"type": "object", "required": ["stage_id", "criterion", "basis"], "properties": {"stage_id": {"type": "string", "pattern": "^run-[0-9]{2}$"}, "criterion": {"type": "string"}, "basis": {"type": "string"}}}}
      }
    },
    "semantic_deviations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "contract_ref", "description", "impact", "status", "approval_ref"],
        "properties": {
          "id": {"type": "string", "pattern": "^dev-[0-9]{3}$"},
          "contract_ref": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1},
          "impact": {"type": "string", "minLength": 1},
          "status": {"enum": ["proposed", "approved", "rejected", "feedback-required"]},
          "approval_ref": {"type": ["string", "null"]}
        }
      }
    }
  }
}
