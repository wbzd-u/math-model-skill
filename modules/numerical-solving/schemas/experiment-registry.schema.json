{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "run_id", "experiments"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "mode": {"enum": ["probe", "solve"]},
    "run_id": {"type": "string", "pattern": "^(probe|solve)-[0-9]{3}$"},
    "experiments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "stage_ids", "status", "command", "working_directory", "input_artifacts", "config_paths", "seed", "started_at", "finished_at", "exit_code", "output_artifacts", "log_path", "metrics", "invariant_results", "failure"],
        "properties": {
          "id": {"type": "string", "pattern": "^exp-[0-9]{3}$"},
          "kind": {"enum": ["probe", "baseline", "main", "alternative", "sensitivity", "robustness", "validation", "benchmark"]},
          "stage_ids": {"type": "array", "items": {"type": "string", "pattern": "^run-[0-9]{2}$"}, "minItems": 1},
          "status": {"enum": ["PLANNED", "RUNNING", "SUCCEEDED", "FAILED", "SKIPPED"]},
          "command": {"type": ["string", "null"]},
          "working_directory": {"type": ["string", "null"]},
          "input_artifacts": {"type": "array", "items": {"type": "object", "required": ["path", "sha256"], "properties": {"path": {"type": "string"}, "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}}}},
          "config_paths": {"type": "array", "items": {"type": "string"}},
          "seed": {"type": ["integer", "null"]},
          "started_at": {"type": ["string", "null"]},
          "finished_at": {"type": ["string", "null"]},
          "exit_code": {"type": ["integer", "null"]},
          "output_artifacts": {"type": "array", "items": {"type": "object", "required": ["path", "sha256", "kind"], "properties": {"path": {"type": "string"}, "sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}, "kind": {"type": "string"}}}},
          "log_path": {"type": ["string", "null"]},
          "metrics": {"type": "array", "items": {"type": "object", "required": ["name", "value", "unit"], "properties": {"name": {"type": "string"}, "value": {"type": ["number", "integer", "string", "boolean", "null"]}, "unit": {"type": ["string", "null"]}}}},
          "invariant_results": {"type": "array", "items": {"type": "object", "required": ["statement", "status", "evidence_ref"], "properties": {"statement": {"type": "string"}, "status": {"enum": ["PASSED", "FAILED", "INCONCLUSIVE", "NOT_RUN"]}, "evidence_ref": {"type": ["string", "null"]}}}},
          "failure": {
            "oneOf": [
              {"type": "null"},
              {"type": "object", "additionalProperties": false, "required": ["category", "message", "trace_ref", "next_action"], "properties": {"category": {"enum": ["implementation_bug", "environment_dependency", "numerical_issue", "data_issue", "contract_model_issue"]}, "message": {"type": "string"}, "trace_ref": {"type": ["string", "null"]}, "next_action": {"type": "string"}}}
            ]
          }
        }
      }
    }
  }
}
