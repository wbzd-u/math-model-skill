{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Paper Argument Map",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "status", "core_argument", "reader_focus", "sections"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "mode": {"enum": ["draft", "final"]},
    "status": {"enum": ["DRAFT", "READY", "BLOCKED"]},
    "core_argument": {"type": ["string", "null"]},
    "reader_focus": {"type": "string", "minLength": 1},
    "sections": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "title", "purpose", "paragraph_jobs", "claim_ids"], "properties": {"id": {"type": "string", "pattern": "^sec-[0-9]{2}$"}, "title": {"type": "string", "minLength": 1}, "purpose": {"type": "string", "minLength": 1}, "paragraph_jobs": {"type": "array", "items": {"enum": ["context", "problem", "approach", "model", "result", "comparison", "validation", "interpretation", "limitation", "conclusion"]}}, "claim_ids": {"type": "array", "items": {"type": "string", "pattern": "^claim-[0-9]{3}$"}}}}}
  }
}
