{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Decision",
  "type": "object",
  "required": ["schema_version", "status", "scope_subproblem_ids", "main_candidate_ids", "baseline_candidate_ids", "alternative_candidate_ids", "baseline_exception", "alternative_exception", "comparisons", "coverage", "decision_rationale", "residual_risks", "route_audit"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "status": {"enum": ["DRAFT", "EXPLORATORY", "READY", "BLOCKED"]},
    "scope_subproblem_ids": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}$"}, "minItems": 1},
    "main_candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^cand-[0-9]{3}$"}},
    "baseline_candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^cand-[0-9]{3}$"}},
    "alternative_candidate_ids": {"type": "array", "items": {"type": "string", "pattern": "^cand-[0-9]{3}$"}},
    "baseline_exception": {"type": ["string", "null"]},
    "alternative_exception": {"type": ["string", "null"]},
    "comparisons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimension", "assessments"],
        "properties": {
          "dimension": {"enum": ["requirement-coverage", "structural-fit", "data-identifiability", "assumptions", "interpretability", "validation", "implementation-cost", "contest-fit", "failure-risk"]},
          "assessments": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["candidate_id", "rating", "evidence_refs", "comment"],
              "properties": {
                "candidate_id": {"type": "string", "pattern": "^cand-[0-9]{3}$"},
                "rating": {"enum": ["strong", "moderate", "weak", "unknown"]},
                "evidence_refs": {"type": "array", "items": {"type": "string"}},
                "comment": {"type": "string", "minLength": 1}
              }
            },
            "minItems": 1
          }
        }
      },
      "minItems": 0
    },
    "coverage": {
      "type": "object",
      "required": ["requirement_ids", "difficulty_refs", "subproblem_ids"],
      "properties": {
        "requirement_ids": {"type": "array", "items": {"type": "string", "pattern": "^req-[0-9]{3}$"}},
        "difficulty_refs": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}:diff-[0-9]{2}$"}},
        "subproblem_ids": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}$"}, "minItems": 1}
      }
    },
    "decision_rationale": {"type": "string", "minLength": 1},
    "residual_risks": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "route_audit": {
      "type": "object",
      "required": ["status", "rationale", "items"],
      "properties": {
        "status": {"enum": ["not-needed", "audited"]},
        "rationale": {"type": "string", "minLength": 1},
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "main_candidate_id", "simpler_candidate_id", "capability_gap", "added_capability", "deciding_test_id", "first_execution_stage_id", "flip_condition", "feedback_trigger"],
            "properties": {
              "id": {"type": "string", "pattern": "^route-audit-[0-9]{2}$"},
              "main_candidate_id": {"type": "string", "pattern": "^cand-[0-9]{3}$"},
              "simpler_candidate_id": {"type": ["string", "null"], "pattern": "^cand-[0-9]{3}$"},
              "capability_gap": {"type": "string", "minLength": 1},
              "added_capability": {"type": "string", "minLength": 1},
              "deciding_test_id": {"type": "string", "pattern": "^val-[0-9]{3}$"},
              "first_execution_stage_id": {"type": "string", "pattern": "^run-[0-9]{2}$"},
              "flip_condition": {"type": "string", "minLength": 1},
              "feedback_trigger": {"type": "string", "minLength": 1}
            }
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "not-needed"}}},
          "then": {"properties": {"items": {"maxItems": 0}}}
        },
        {
          "if": {"properties": {"status": {"const": "audited"}}},
          "then": {"properties": {"items": {"minItems": 1}}}
        }
      ]
    }
  }
}
