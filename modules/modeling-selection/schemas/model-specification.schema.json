{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Model Specification",
  "type": "object",
  "required": ["schema_version", "status", "scope_subproblem_ids", "notation", "new_assumptions", "components", "model_chain", "immutable_semantics"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "status": {"enum": ["DRAFT", "EXPLORATORY", "READY", "BLOCKED"]},
    "scope_subproblem_ids": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}$"}, "minItems": 1},
    "notation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source_variable_id", "symbol", "definition", "unit"],
        "properties": {
          "id": {"type": "string", "pattern": "^(var|dvar)-[0-9]{3}$"},
          "source_variable_id": {"type": "string", "pattern": "^(var|dvar)-[0-9]{3}$"},
          "symbol": {"type": "string", "minLength": 1},
          "definition": {"type": "string", "minLength": 1},
          "unit": {"type": "string", "minLength": 1}
        }
      },
      "minItems": 0
    },
    "new_assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "basis", "affected_subproblem_ids", "validation_method", "status"],
        "properties": {
          "id": {"type": "string", "pattern": "^sel-asm-[0-9]{3}$"},
          "statement": {"type": "string", "minLength": 1},
          "basis": {"type": "string", "minLength": 1},
          "affected_subproblem_ids": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}$"}, "minItems": 1},
          "validation_method": {"type": "string", "minLength": 1},
          "status": {"enum": ["proposed", "approved", "rejected"]}
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "candidate_id", "role", "subproblem_ids", "type", "purpose", "formal_definition", "input_variable_ids", "output_variable_ids", "objective_statements", "constraint_statements", "state_or_event_relations", "parameter_sources", "upstream_component_ids"],
        "properties": {
          "id": {"type": "string", "pattern": "^cmp-[0-9]{3}$"},
          "candidate_id": {"type": "string", "pattern": "^cand-[0-9]{3}$"},
          "role": {"enum": ["baseline", "main", "alternative", "validation"]},
          "subproblem_ids": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}$"}, "minItems": 1},
          "type": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "formal_definition": {"type": "string", "minLength": 1},
          "input_variable_ids": {"type": "array", "items": {"type": "string", "pattern": "^(var|dvar)-[0-9]{3}$"}},
          "output_variable_ids": {"type": "array", "items": {"type": "string", "pattern": "^(var|dvar)-[0-9]{3}$"}, "minItems": 1},
          "objective_statements": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "constraint_statements": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "state_or_event_relations": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "parameter_sources": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "upstream_component_ids": {"type": "array", "items": {"type": "string", "pattern": "^cmp-[0-9]{3}$"}}
        }
      },
      "minItems": 0
    },
    "model_chain": {
      "type": "object",
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {"type": "array", "items": {"type": "string", "pattern": "^cmp-[0-9]{3}$"}},
        "edges": {"type": "array", "items": {"type": "object", "required": ["from", "to", "artifact"], "properties": {"from": {"type": "string", "pattern": "^cmp-[0-9]{3}$"}, "to": {"type": "string", "pattern": "^cmp-[0-9]{3}$"}, "artifact": {"type": "string", "minLength": 1}}}}
      }
    },
    "immutable_semantics": {"type": "array", "items": {"type": "object", "required": ["source_ref", "statement"], "properties": {"source_ref": {"type": "string", "minLength": 1}, "statement": {"type": "string", "minLength": 1}}}}
  }
}
