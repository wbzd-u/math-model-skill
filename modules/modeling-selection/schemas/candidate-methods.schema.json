{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Method Chains",
  "type": "object",
  "required": ["schema_version", "knowledge_status", "evidence_records", "candidates", "comparison_exception"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "knowledge_status": {"enum": ["not-searched", "none-available", "partial", "sufficient"]},
    "comparison_exception": {"type": ["string", "null"]},
    "evidence_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "source_ref", "relevance", "transfer_limits", "verified"],
        "properties": {
          "id": {"type": "string", "pattern": "^ev-[0-9]{3}$"},
          "type": {"enum": ["historical-case", "method-card", "validation-card", "literature", "structural", "competition-rule", "data"]},
          "title": {"type": "string", "minLength": 1},
          "source_ref": {"type": "string", "minLength": 1},
          "relevance": {"type": "string", "minLength": 1},
          "transfer_limits": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "verified": {"type": "boolean"}
        }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "subproblem_ids", "chain_roles", "requirement_ids", "difficulty_refs", "data_ids", "evidence_ids", "assumptions", "output_type", "validation_plan", "risks", "rejection_conditions", "transfer_limits", "implementation_cost", "interpretability", "validation_strength", "contest_fit", "status"],
        "properties": {
          "id": {"type": "string", "pattern": "^cand-[0-9]{3}$"},
          "name": {"type": "string", "minLength": 1},
          "subproblem_ids": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}$"}, "minItems": 1, "uniqueItems": true},
          "chain_roles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "role", "method_family", "purpose", "input_refs", "output_refs", "evidence_ids"],
              "properties": {
                "id": {"type": "string", "pattern": "^stage-[0-9]{2}$"},
                "role": {"enum": ["state-representation", "parameter-estimation", "prediction", "evaluation", "optimization", "simulation", "aggregation", "uncertainty", "validation", "other"]},
                "method_family": {"type": "string", "minLength": 1},
                "purpose": {"type": "string", "minLength": 1},
                "input_refs": {"type": "array", "items": {"type": "string"}},
                "output_refs": {"type": "array", "items": {"type": "string"}},
                "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^ev-[0-9]{3}$"}}
              }
            },
            "minItems": 1
          },
          "requirement_ids": {"type": "array", "items": {"type": "string", "pattern": "^req-[0-9]{3}$"}, "minItems": 1, "uniqueItems": true},
          "difficulty_refs": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}:diff-[0-9]{2}$"}},
          "data_ids": {"type": "array", "items": {"type": "string", "pattern": "^data-[0-9]{2}$"}},
          "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^ev-[0-9]{3}$"}},
          "assumptions": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "output_type": {"type": "string", "minLength": 1},
          "validation_plan": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "risks": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "rejection_conditions": {"type": "array", "items": {"type": "string", "minLength": 1}, "minItems": 1},
          "transfer_limits": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "implementation_cost": {"enum": ["low", "moderate", "high", "unknown"]},
          "interpretability": {"enum": ["strong", "moderate", "weak", "unknown"]},
          "validation_strength": {"enum": ["strong", "moderate", "weak", "unknown"]},
          "contest_fit": {"enum": ["strong", "moderate", "weak", "unknown"]},
          "status": {"enum": ["candidate", "selected", "rejected"]}
        }
      }
    }
  }
}
