{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Task Matrix",
  "type": "object",
  "required": ["schema_version", "mappings"],
  "properties": {
    "schema_version": {"const": "0.2.0"},
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subproblem_id", "needs"],
        "properties": {
          "subproblem_id": {"type": "string", "pattern": "^sp-[0-9]{2}$"},
          "needs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["item", "status", "data_ids", "field_refs", "gap", "impact"],
              "properties": {
                "item": {"type": "string", "minLength": 1},
                "status": {"enum": ["available", "derivable", "external-required", "assumption-required", "missing", "not-applicable"]},
                "data_ids": {"type": "array", "items": {"type": "string", "pattern": "^data-[0-9]{2}$"}},
                "field_refs": {"type": "array", "items": {"type": "string"}},
                "gap": {"type": ["string", "null"]},
                "impact": {"type": ["string", "null"]}
              }
            }
          }
        }
      }
    }
  }
}
