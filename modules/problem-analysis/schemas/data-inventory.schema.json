{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Inventory",
  "type": "object",
  "required": ["schema_version", "datasets"],
  "properties": {
    "schema_version": {"const": "0.2.0"},
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "format", "role", "read_only", "fields", "issues"],
        "properties": {
          "id": {"type": "string", "pattern": "^data-[0-9]{2}$"},
          "path": {"type": "string"},
          "format": {"type": "string"},
          "role": {"type": "string"},
          "read_only": {"const": true},
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "type", "unit", "description"],
              "properties": {
                "name": {"type": "string"},
                "type": {"type": ["string", "null"]},
                "unit": {"type": ["string", "null"]},
                "description": {"type": ["string", "null"]}
              }
            }
          },
          "issues": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
