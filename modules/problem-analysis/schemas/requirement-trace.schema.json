{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirement Trace",
  "type": "object",
  "required": ["schema_version", "requirements"],
  "properties": {
    "schema_version": {"const": "0.2.0"},
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement", "category", "source_ref", "subproblem_ids", "status"],
        "properties": {
          "id": {"type": "string", "pattern": "^req-[0-9]{3}$"},
          "statement": {"type": "string", "minLength": 1},
          "category": {"enum": ["background", "fact", "input", "objective", "constraint", "output", "evaluation"]},
          "source_ref": {"type": "string", "minLength": 1},
          "subproblem_ids": {"type": "array", "items": {"type": "string", "pattern": "^sp-[0-9]{2}$"}},
          "status": {"enum": ["mapped", "open", "blocked"]}
        }
      }
    }
  }
}
